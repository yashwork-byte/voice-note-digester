# Sarvam API key — used ONLY by scripts/synthesize_eval_data.py (Bulbul TTS).
# The runtime pipeline is fully on-device and must never read this.
SARVAM_API_KEY=

# Optional: pulling gated/eval datasets from Hugging Face.
HF_TOKEN=

# Modal secrets are NOT stored here — create them once with the Modal CLI:
#   modal secret create huggingface-secret HF_TOKEN=hf_xxxxxxxx
